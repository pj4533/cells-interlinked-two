# Server
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# Target model M and the matching kitft NLA actor (AV).
# Defaults validated for M2 Ultra 64GB at bf16.
MODEL_NAME=Qwen/Qwen2.5-7B-Instruct
AV_REPO=kitft/nla-qwen2.5-7b-L20-av
EXTRACTION_LAYER=20

# Generation knobs for M.
TEMPERATURE=0.7
TOP_P=0.9
SEED=42

# AV decoding knobs.
NLA_MAX_NEW_TOKENS=180
NLA_TEMPERATURE=1.0

DB_PATH=./data/probes.sqlite
DTYPE=bfloat16
DEVICE=mps

# Anthropic API key for journal analyzer.
ANTHROPIC_API_KEY=sk-ant-...
ANALYZER_MODEL=claude-opus-4-7

AUTORUN_INTERVAL_SEC=5
