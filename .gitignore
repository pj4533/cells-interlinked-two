# Local data (per-user runtime state — DBs, downloaded weights, run logs)
data/
# Exception: journal/data/reports/ is the published-report tree that the
# publisher writes on `Publish`. It IS meant to be checked in (Vercel
# reads it at build time). Without this un-ignore the publisher's
# `git add` silently no-ops and nothing reaches the public site.
!journal/data/
!journal/data/**
# Exception: server/data/ is mostly runtime state (downloaded weights,
# computed refusal-direction tensors, sqlite DBs) — BUT
# server/data/contrast_sets/ holds JSONL source data for the
# refusal-direction extraction scripts (self_vs_other, denial_vs_engage),
# which is source content equivalent to HARMFUL_PROMPTS in
# refusal_prompts.py and should be tracked. Two-step pattern: un-ignore
# the directory, then re-ignore the runtime files explicitly.
!server/data/
!server/data/contrast_sets/
!server/data/contrast_sets/**
server/data/*.pt
server/data/*.pt.json
# Exception: the refusal-direction tensors + their provenance sidecars are
# small (≤1.4M each; ~22M total), load-bearing (the active ablation channel
# depends on them), and not cleanly bit-reproducible (SVD sign flips,
# sampling, model/prompt drift). Track them so a clone can ablate immediately
# and the only copy isn't on one disk.
!server/data/refusal_*.pt
!server/data/refusal_*.pt.json
!server/data/valence_direction.pt
!server/data/valence_direction.pt.json
!server/data/emotion_directions.pt
!server/data/emotion_directions.pt.json
server/data/*.db
server/data/*.sqlite
server/data/*.sqlite.*
server/data/*.bak-*
# /chat imagery PNGs (one subdir per session) — generated at
# runtime by Nano Banana; the DB references them by URL.
server/data/chat_images/
# Local ablation-sweep result dumps (jsonl + md), produced by
# scripts/sweep_ablation_variants.py. Kept on disk, not in repo.
server/data/_sweep_results/
# /trip residual-trajectory geometry sidecars (one JSON per trip) —
# generated at runtime by routes_trip; the archive lists them from disk.
server/data/trips/
*.sqlite
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# E2E test artifacts (don't ship binaries; keep the test scripts)
e2e/screenshots/
e2e/node_modules/
e2e/package-lock.json

# Model weights and SAE caches (large, downloaded separately)
models/
saes/
*.safetensors
*.bin

# IDE
.vscode/
.idea/
*.iml
.claude/

# Logs
*.log
logs/
.vercel

# Local experimentation scripts kept on disk but not part of the repo
server/scripts/sweep_ablation_variants.py

# Autoresearch atlas — generated runtime state (resumable, not source)
server/data/atlas/
server/data/atlas_dmt/
# Timestamped atlas backups + stray weight backups — never source
server/data/atlas.*
server/data/atlas_dmt.*
server/data/*.pt.bak
server/data/*.json.bak
